#Customer Lifetime Value (CLV)
SELECT
c.customer_name,
SUM(o.quantity*p.price) AS lifetime_value
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN products p
ON o.product_id=p.product_id
GROUP BY c.customer_name
ORDER BY lifetime_value DESC;

#Most Expensive Product
SELECT *
FROM products
ORDER BY price DESC
LIMIT 1;

#Customers Who Ordered More Than Once
SELECT
c.customer_name,
COUNT(o.order_id) AS total_orders
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
GROUP BY c.customer_name
HAVING COUNT(o.order_id)>1;

#Top Customer in Each City (Window Function)
WITH customer_revenue AS
(SELECT
c.city,
c.customer_name,
SUM(o.quantity*p.price) AS revenue
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN products p
ON o.product_id=p.product_id
GROUP BY c.city,c.customer_name)

SELECT *
FROM
(SELECT *,
RANK() OVER(PARTITION BY city ORDER BY revenue DESC) AS ranking
FROM customer_revenue)t
WHERE ranking=1;

#Running Revenue (Window Function)
SELECT
order_date,
SUM(quantity*price) OVER(ORDER BY order_date) AS running_revenue
FROM orders o
JOIN products p
ON o.product_id=p.product_id;

#Customer Segmentation
SELECT
customer_name,
revenue,
CASE
WHEN revenue>=10000 THEN 'Premium'
WHEN revenue>=5000 THEN 'Gold'
ELSE 'Regular'
END AS customer_segment
FROM
(SELECT
c.customer_name,
SUM(o.quantity*p.price) AS revenue
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN products p
ON o.product_id=p.product_id
GROUP BY c.customer_name)t;
